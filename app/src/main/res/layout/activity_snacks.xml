<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ActivitySnacks"
    android:background="@color/black">
    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <ImageView
                android:contentDescription="@string/cinefast_logo_content_description"
                android:layout_margin="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/cinefast_branding"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="12dp"
                android:text="Select Items"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="Snacks And Drinks"
                android:textSize="20sp"
                android:layout_margin="12dp"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@color/navy_blue"
                android:orientation="horizontal"
                >
                <ImageView
                    android:contentDescription="Image of popcorn at cineFAST"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_margin="12dp"
                    android:src="@drawable/popcorn"
                    />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="4"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        >
                        <TextView
                            android:id="@+id/tv_popcorn_title"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="Popcorn"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginLeft="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />

                        <TextView
                            android:id="@+id/tv_popcorn_price"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="$ 9.99"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textAlignment="textEnd"
                            android:layout_marginRight="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />




                    </LinearLayout>


                    <TextView
                        android:id="@+id/tv_popcorn_description"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Large | Buttered"
                        android:layout_marginLeft="12dp"
                        android:textColor="@color/white"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        >
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/remove_popcorn"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="match_parent"
                            android:backgroundTint="@color/white"
                            android:textColor="@color/black"
                            android:layout_margin="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/remove_from_cart"
                            app:iconTint="@color/black"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />
                        <EditText
                            android:id="@+id/et_popcorn_quantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:autoSizeTextType="uniform"
                            android:textAlignment="center"
                            android:inputType="number"

                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/add_popcorn"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"

                            android:backgroundTint="@color/red"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/add_to_cart"
                            app:iconTint="@color/white"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            >

                        </View>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@color/navy_blue"
                android:orientation="horizontal"
                >
                <ImageView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_margin="12dp"
                    android:src="@drawable/nachos"
                    />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="4"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        >
                        <TextView
                            android:id="@+id/tv_nachos_title"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="Nachos"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginLeft="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />

                        <TextView
                            android:id="@+id/tv_nachos_price"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="$ 9.99"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textAlignment="textEnd"
                            android:layout_marginRight="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />




                    </LinearLayout>


                    <TextView
                        android:id="@+id/tv_nachos_description"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Large | With Cheese And Salsa"
                        android:layout_marginLeft="12dp"
                        android:textColor="@color/white"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        >
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/remove_nachos"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="match_parent"
                            android:backgroundTint="@color/white"
                            android:textColor="@color/black"
                            android:layout_margin="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/remove_from_cart"
                            app:iconTint="@color/black"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />
                        <EditText
                            android:id="@+id/et_nachos_quantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:autoSizeTextType="uniform"
                            android:textAlignment="center"
                            android:inputType="number"

                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/add_nachos"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"

                            android:backgroundTint="@color/red"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/add_to_cart"
                            app:iconTint="@color/white"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            >

                        </View>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@color/navy_blue"
                android:orientation="horizontal"
                >
                <ImageView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_margin="12dp"
                    android:src="@drawable/fries"
                    />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="4"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        >
                        <TextView
                            android:id="@+id/tv_fries_title"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="French Fries"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginLeft="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />

                        <TextView
                            android:id="@+id/tv_fries_price"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="$ 9.99"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textAlignment="textEnd"
                            android:layout_marginRight="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />




                    </LinearLayout>


                    <TextView
                        android:id="@+id/tv_fries_description"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Large | Salted"
                        android:layout_marginLeft="12dp"
                        android:textColor="@color/white"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        >
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/remove_fries"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="match_parent"
                            android:backgroundTint="@color/white"
                            android:textColor="@color/black"
                            android:layout_margin="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/remove_from_cart"
                            app:iconTint="@color/black"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />
                        <EditText
                            android:id="@+id/et_fries_quantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:autoSizeTextType="uniform"
                            android:textAlignment="center"
                            android:inputType="number"

                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/add_fries"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"

                            android:backgroundTint="@color/red"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/add_to_cart"
                            app:iconTint="@color/white"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            >

                        </View>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@color/navy_blue"
                android:orientation="horizontal"
                >
                <ImageView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_margin="12dp"
                    android:src="@drawable/hot_dogs"
                    />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="4"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        >
                        <TextView
                            android:id="@+id/tv_hot_dogs_title"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="Hot Dogs"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginLeft="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />

                        <TextView
                            android:id="@+id/tv_hot_dogs_price"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="$ 9.99"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textAlignment="textEnd"
                            android:layout_marginRight="12dp"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/white"
                            />




                    </LinearLayout>


                    <TextView
                        android:id="@+id/tv_hot_dogs_description"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Large | With Mustard and Ketchup"
                        android:layout_marginLeft="12dp"
                        android:layout_marginRight="12dp"
                        android:textColor="@color/white"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        >
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/remove_hot_dogs"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="match_parent"
                            android:backgroundTint="@color/white"
                            android:textColor="@color/black"
                            android:layout_margin="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/remove_from_cart"
                            app:iconTint="@color/black"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />
                        <EditText
                            android:id="@+id/et_hot_dogs_quantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:autoSizeTextType="uniform"
                            android:textAlignment="center"
                            android:inputType="number"

                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/add_hot_dogs"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"

                            android:backgroundTint="@color/red"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_marginTop="8dp"

                            android:padding="0dp"
                            android:text=""

                            app:icon="@drawable/add_to_cart"
                            app:iconTint="@color/white"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconGravity="textStart"
                            app:cornerRadius="10dp"
                            />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            >

                        </View>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="12dp"
                >

                <Button
                    android:id="@+id/button_snacks_continue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/red"
                    android:text="Continue"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:autoSizeTextType="uniform"
                    android:textStyle="bold"
                    />

            </LinearLayout>




        </LinearLayout>
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>