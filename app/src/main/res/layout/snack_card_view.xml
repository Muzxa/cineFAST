<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="20dp"
    android:backgroundTint="@color/navy_blue"
    android:layout_margin="8dp"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@color/navy_blue"
        android:orientation="horizontal"
        >
        <ImageView
            android:id="@+id/iv_snack_image"
            android:contentDescription="Image of popcorn at cineFAST"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            android:src="@drawable/popcorn"
            />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="4"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                >
                <TextView
                    android:id="@+id/tv_snack_title"
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Popcorn"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginLeft="12dp"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/white"
                    />

                <TextView
                    android:id="@+id/tv_snack_price"
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="$ 9.99"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textAlignment="textEnd"
                    android:layout_marginRight="12dp"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/white"
                    />




            </LinearLayout>


            <TextView
                android:id="@+id/tv_snack_description"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Large | Buttered"
                android:layout_marginLeft="12dp"
                android:textColor="@color/white"
                />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                >
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_remove_snack"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/black"
                    android:layout_margin="8dp"

                    android:padding="0dp"
                    android:text=""

                    app:icon="@drawable/remove_from_cart"
                    app:iconTint="@color/black"
                    app:iconPadding="0dp"
                    app:iconSize="28dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="10dp"
                    />
                <EditText
                    android:id="@+id/et_snack_quantity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:textAlignment="center"
                    android:inputType="number"

                    android:layout_marginRight="8dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="8dp"

                    />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_snack"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"

                    android:backgroundTint="@color/red"
                    android:layout_marginRight="8dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="8dp"

                    android:padding="0dp"
                    android:text=""

                    app:icon="@drawable/add_to_cart"
                    app:iconTint="@color/white"
                    app:iconPadding="0dp"
                    app:iconSize="28dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="10dp"
                    />

                <View
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    >

                </View>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>