<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ActivityMovieList"
    android:background="@color/black">
    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <ImageView
            android:contentDescription="@string/cinefast_logo_content_description"
            android:layout_margin="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/cinefast_branding"
            />


            <com.google.android.material.tabs.TabLayout
                android:id="@+id/movie_list_tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:tabIndicatorColor="@color/red"
                app:tabTextColor="@color/white"
                app:tabSelectedTextColor="@color/red"
                android:backgroundTint="@color/black"
                >

                <com.google.android.material.tabs.TabItem
                    android:id="@+id/movie_list_tab_layout_now_showing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Now Showing"

                    />

                <com.google.android.material.tabs.TabItem
                    android:id="@+id/movie_list_tab_layout_coming_soon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Coming Soon"
                    />


            </com.google.android.material.tabs.TabLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/movie_list_view_pager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            />



    </LinearLayout>
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>