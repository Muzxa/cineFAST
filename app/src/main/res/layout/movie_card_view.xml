<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="20dp"
    android:backgroundTint="@color/navy_blue"
    android:layout_margin="8dp"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12sp"
        android:background="@color/navy_blue"
        android:orientation="horizontal"
        >
        <ImageView
            android:id="@+id/iv_movie_card_poster"
            android:layout_width="0sp"
            android:layout_weight="1"
            android:layout_height="100sp"
            android:layout_margin="12sp"
            android:src="@drawable/oppenheimer"
            />

        <LinearLayout
            android:layout_width="0sp"
            android:layout_weight="4"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <TextView
                android:id="@+id/tv_movie_card_title"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Oppenheimer"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_marginLeft="12sp"
                android:layout_marginTop="12sp"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/tv_movie_card_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12sp"
                android:text="Thriller / 180 min"
                android:textColor="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                >
                <Button
                    android:id="@+id/button_movie_card_book_seats"
                    android:layout_width="0sp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:backgroundTint="@color/red"
                    android:textSize="16sp"
                    android:autoSizeTextType="uniform"
                    android:text="Book Seats"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_margin="8sp"
                    />
                <Button
                    android:id="@+id/button_movie_card_trailer"
                    android:layout_width="0sp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    android:text="Trailer"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:autoSizeTextType="uniform"
                    android:layout_marginRight="8sp"
                    android:layout_marginBottom="8sp"
                    android:layout_marginTop="8sp"
                    />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>